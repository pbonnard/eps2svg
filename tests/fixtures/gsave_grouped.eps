%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 300 300
%%EndComments
0 0 0 setrgbcolor
gsave
  newpath 50 50 20 0 360 arc fill
  newpath 30 50 moveto 70 50 lineto stroke
grestore
gsave
  newpath 250 50 20 0 360 arc fill
  newpath 230 50 moveto 270 50 lineto stroke
grestore
gsave
  newpath 50 250 20 0 360 arc fill
  newpath 30 250 moveto 70 250 lineto stroke
grestore
gsave
  newpath 250 250 20 0 360 arc fill
  newpath 230 250 moveto 270 250 lineto stroke
grestore
showpage
%%EOF
