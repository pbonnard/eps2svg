%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 300 100
%%EndComments
0 0 0 setrgbcolor
% Three icons in a row, each wrapped in gsave/grestore.
gsave  newpath  50 50 20 0 360 arc fill  grestore
gsave  newpath 150 50 20 0 360 arc fill  grestore
gsave  newpath 250 50 20 0 360 arc fill  grestore
% One small loose decorative dot (no gsave wrap), near the middle icon
newpath 160 50 3 0 360 arc fill
showpage
%%EOF
